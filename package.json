{
  "name": "bookmarker-for-nextcloud",
  "version": "0.32.0",
  "type": "module",
  "description": "Browser extension for managing Nextcloud bookmarks",
  "keywords": [
    "nextcloud",
    "bookmarks",
    "browser-extension",
    "chrome-extension"
  ],
  "author": "plushbyte",
  "license": "ISC",
  "homepage": "https://plushbyte.com/chrome/bookmarker-for-nextcloud",
  "repository": {
    "type": "git",
    "url": "https://github.com/plushbyte/bookmarker-for-nextcloud"
  },
  "bugs": {
    "url": "https://github.com/plushbyte/bookmarker-for-nextcloud/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rm -f src/options/options.css src/popup/css/popup.css",
    "clean:dist": "rm -rf dist .parcel-cache",
    "build:css:options": "npx @tailwindcss/cli -i ./src/options/input.css -o ./src/options/options.css --minify",
    "build:css:popup": "npx @tailwindcss/cli -i ./src/popup/css/input.css -o ./src/popup/css/popup.css --minify",
    "build:css": "npm run build:css:options && npm run build:css:popup",
    "prebuild": "npm run clean && npm run clean:dist",
    "build": "npm run build:css && vite build",
    "predev": "npm run clean && npm run clean:dist",
    "dev": "npm run build:css && vite",
    "watch": "npm run build:css && vite",
    "prebuild:dev": "npm run clean && npm run clean:dist",
    "build:dev": "npm run build:css && vite build --mode development",
    "pred deploy": "npm run clean && npm run clean:dist",
    "deploy": "npm run build:css && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "sonar:scan": "npm run test:coverage && sonar-scanner"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@linthtml/linthtml": "^0.10.2",
    "@tailwindcss/cli": "^4.2.2",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "daisyui": "^5.5.19",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup": "^4.60.0",
    "sonarqube-scanner": "^4.3.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@yaireo/tagify": "^4.36.0",
    "idb": "^8.0.3",
    "textfit": "^2.4.0"
  }
}
